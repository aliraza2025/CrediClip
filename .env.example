# Optional AI or Not integration
AIORNOT_API_KEY=
AIORNOT_VIDEO_ENDPOINT=

# Optional OpenRouter LLM (free-tier capable for claim verification)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
# Optional headers some models/providers prefer:
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=CrediClip

# Local ASR/OCR tuning
WHISPER_MODEL_SIZE=small
WHISPER_COMPUTE_TYPE=int8
OCR_FRAME_FPS=1
OCR_MAX_FRAMES=8
