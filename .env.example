# Optional AI or Not integration
AIORNOT_API_KEY=
AIORNOT_VIDEO_ENDPOINT=

# Optional OpenRouter LLM (free-tier capable for claim verification)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# Optional comma-separated fallbacks (tried in order if primary fails/rate-limits):
OPENROUTER_MODEL_FALLBACKS=meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-4b:free
# Optional headers some models/providers prefer:
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=CrediClip

# Optional local LLM on VM (Ollama)
# CLAIM_LLM_MODE: auto|ollama|openai|openrouter|groq|none
CLAIM_LLM_MODE=auto
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
OLLAMA_TIMEOUT_SEC=45
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SEC=45
OPENAI_MAX_RETRIES=2
OPENAI_CLAIM_ALLOWED_PLATFORMS=instagram,tiktok,youtube_shorts
OPENAI_CLAIM_MIN_TOKENS=50
OPENAI_CLAIM_MIN_EVIDENCE_LEVEL=medium
OPENAI_CLAIM_MIN_TOKENS_INSTAGRAM=60
OPENAI_CLAIM_MIN_EVIDENCE_LEVEL_INSTAGRAM=medium
OPENAI_CLAIM_MIN_TOKENS_TIKTOK=50
OPENAI_CLAIM_MIN_EVIDENCE_LEVEL_TIKTOK=medium
OPENAI_CLAIM_MIN_TOKENS_YOUTUBE_SHORTS=20
OPENAI_CLAIM_MIN_EVIDENCE_LEVEL_YOUTUBE_SHORTS=low

# Local ASR/OCR tuning
# TRANSCRIPTION_PROVIDER: local|openai|auto|none
TRANSCRIPTION_PROVIDER=auto
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TRANSCRIPTION_TIMEOUT_SEC=60
OPENAI_TRANSCRIPTION_PROMPT=
WHISPER_MODEL_SIZE=small
WHISPER_COMPUTE_TYPE=int8
OCR_FRAME_FPS=1
OCR_MAX_FRAMES=8

# Optional browser-rendered watch-page fallback (Oracle worker recommended)
BROWSER_INGESTION_ENABLED=0
BROWSER_INGESTION_HEADLESS=1
BROWSER_INGESTION_TIMEOUT_SEC=30
BROWSER_INGESTION_USER_AGENT=

# Optional official YouTube Data API metadata fallback
YOUTUBE_DATA_API_KEY=
YOUTUBE_DATA_API_PARTS=snippet
YOUTUBE_DATA_API_TIMEOUT_SEC=15

# Optional yt-dlp auth for blocked Shorts extraction (use one):
# 1) Path to Netscape cookie file available in runtime container
YTDLP_COOKIE_FILE=
# 2) Base64-encoded Netscape cookie file content (recommended for Fly secrets)
YTDLP_COOKIES_B64=
# 3) Optional YouTube anti-bot session hints (temporary; rotate often)
YTDLP_VISITOR_DATA=
YTDLP_PO_TOKEN_WEB=
YTDLP_PO_TOKEN_ANDROID=

# API memory safety (recommended for Fly free-tier)
# Keep heavy media extraction disabled on web API nodes (workers can still run rich ingestion).
ENABLE_HEAVY_INGESTION=0
# Limit in-process analysis concurrency to avoid RAM spikes.
ANALYZE_MAX_CONCURRENCY=1
# Hard timeout to prevent stuck analysis jobs from piling memory.
ANALYZE_TIMEOUT_SEC=180
