# Free-only defaults
CLAIM_LLM_MODE=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Best realistic open model for Oracle Always Free-sized worker: qwen3:4b
# Use qwen3:8b only on materially larger RAM.
OLLAMA_MODEL=qwen3:4b
OLLAMA_TIMEOUT_SEC=180
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=220

# Optional hosted OpenAI claim reasoning
# Switch CLAIM_LLM_MODE to openai when OPENAI_API_KEY is available.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SEC=45
OPENAI_MAX_RETRIES=2
OPENAI_CLAIM_ALLOWED_PLATFORMS=instagram,tiktok,youtube_shorts
OPENAI_CLAIM_MIN_TOKENS=50
OPENAI_CLAIM_MIN_EVIDENCE_LEVEL=medium
OPENAI_CLAIM_MIN_TOKENS_INSTAGRAM=60
OPENAI_CLAIM_MIN_EVIDENCE_LEVEL_INSTAGRAM=medium
OPENAI_CLAIM_MIN_TOKENS_TIKTOK=50
OPENAI_CLAIM_MIN_EVIDENCE_LEVEL_TIKTOK=medium
OPENAI_CLAIM_MIN_TOKENS_YOUTUBE_SHORTS=20
OPENAI_CLAIM_MIN_EVIDENCE_LEVEL_YOUTUBE_SHORTS=low
TRANSCRIPTION_PROVIDER=auto
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TRANSCRIPTION_TIMEOUT_SEC=60
OPENAI_TRANSCRIPTION_PROMPT=

# Queue worker settings
API_BASE=https://crediclip-axraza-msba.fly.dev
WORKER_ID=oracle-worker-1
INGEST_MODE=rich
ANALYSIS_MODE=server
POLL_SEC=3
TIMEOUT_SEC=180

# Optional browser-rendered ingestion fallback (no Google API needed)
BROWSER_INGESTION_ENABLED=1
BROWSER_INGESTION_HEADLESS=1
BROWSER_INGESTION_TIMEOUT_SEC=30
BROWSER_INGESTION_USER_AGENT=

# Optional official YouTube metadata API fallback
YOUTUBE_DATA_API_KEY=
YOUTUBE_DATA_API_PARTS=snippet
YOUTUBE_DATA_API_TIMEOUT_SEC=15

# Optional YouTube auth (recommended for bot-blocked Shorts)
# Prefer a dedicated account/cookies for the worker, not your primary personal profile.
YTDLP_COOKIE_FILE=/home/ubuntu/youtube_cookies.txt
YTDLP_VISITOR_DATA=
YTDLP_PO_TOKEN_WEB=
YTDLP_PO_TOKEN_ANDROID=

# Optional Instagram worker auth (recommended for richer Reel media access)
# Use a separate Netscape cookie export for Instagram if available.
INSTAGRAM_COOKIE_FILE=/home/ubuntu/instagram_cookies.txt
INSTAGRAM_COOKIES_B64=
INSTAGRAM_BROWSER_TIMEOUT_SEC=35
INSTAGRAM_BROWSER_HEADLESS=1
INSTAGRAM_BROWSER_OCR_SAMPLES=3

# Optional TikTok worker browser/media ingest
TIKTOK_COOKIE_FILE=/home/ubuntu/tiktok_cookies.txt
TIKTOK_COOKIES_B64=
TIKTOK_BROWSER_TIMEOUT_SEC=35
TIKTOK_BROWSER_HEADLESS=1
TIKTOK_BROWSER_OCR_SAMPLES=3
